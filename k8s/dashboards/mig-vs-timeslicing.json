{
  "dashboard": {
    "title": "GPU MIG vs Time Slicing - Cost & Performance",
    "uid": "mig-vs-timeslicing",
    "version": 1,
    "refresh": "30s",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Total Infrastructure Cost (EUR)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "7.66",
            "legendFormat": "Total Cost",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currency EUR",
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 50, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Compute Cost",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "6.97",
            "legendFormat": "Compute",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currency EUR",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 10, "color": "yellow"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "GPU Mode",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "1",
            "legendFormat": "Mode",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"0": {"text": "Time Slicing"}}},
              {"type": "value", "options": {"1": {"text": "MIG"}}}
            ],
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "blue", "title": "Time Slicing"}},
                {"value": 1, "color": "purple", "title": "MIG"}}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Active GPU Instances",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "1",
            "legendFormat": "GPUs",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 1, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "GPU Utilization %",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "rate(nvidia_dcgm_exporter_gpu_utilization_seconds_total[1m]) * 100",
            "legendFormat": "GPU {{gpu}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {"lineWidth": 2},
            "color": {"mode": "palette-classic"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 50, "color": "yellow"},
                {"value": 90, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "GPU Memory Usage",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "nvidia_dcgm_exporter_memory_used_bytes / 1024 / 1024",
            "legendFormat": "Used MB - GPU {{gpu}}",
            "refId": "A"
          },
          {
            "expr": "nvidia_dcgm_exporter_memory_total_bytes / 1024 / 1024",
            "legendFormat": "Total MB - GPU {{gpu}}",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "decmbytes",
            "custom": {"lineWidth": 2},
            "color": {"mode": "palette-classic"}
          }
        }
      },
      {
        "id": 7,
        "title": "Cost by Product",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "6.42",
            "legendFormat": "H100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currency EUR",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 5, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            },
            "custom": {"displayMode": "gradient"}
          }
        }
      },
      {
        "id": 8,
        "title": "Cost by Category",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
        "targets": [
          {
            "expr": "6.97",
            "legendFormat": "Compute",
            "refId": "A"
          }
        ]
      },
      {
        "id": 9,
        "title": "Instance Details",
        "type": "table",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
        "targets": [
          {
            "expr": "kube_pod_info",
            "legendFormat": "{{pod}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 10,
        "title": "GPU Temperature",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "45",
            "legendFormat": "Temp",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "max": 100,
            "min": 0,
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "blue"},
                {"value": 70, "color": "green"},
                {"value": 85, "color": "yellow"},
                {"value": 95, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 11,
        "title": "GPU Power Draw",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 20},
        "targets": [
          {
            "expr": "150",
            "legendFormat": "Watts",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "watt",
            "max": 400,
            "min": 0,
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "blue"},
                {"value": 200, "color": "green"},
                {"value": 300, "color": "yellow"},
                {"value": 350, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 12,
        "title": "Container Count",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 20},
        "targets": [
          {
            "expr": "count(kube_pod_container_info)",
            "legendFormat": "Containers",
            "refId": "A"
          }
        ]
      },
      {
        "id": 13,
        "title": "Pod Memory Request",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "kube_pod_container_resource_requests_memory_bytes",
            "legendFormat": "{{pod}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": {"lineWidth": 1}
          }
        }
      },
      {
        "id": 14,
        "title": "Estimated Hourly Cost",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 28},
        "targets": [
          {
            "expr": "0.85",
            "legendFormat": "H100-1-80G",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currency EUR",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 5, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 15,
        "title": "Estimated Monthly Cost",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 28},
        "targets": [
          {
            "expr": "0.85 * 24 * 30",
            "legendFormat": "Monthly",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currency EUR",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 500, "color": "yellow"},
                {"value": 1000, "color": "red"}
              ]
            }
          }
        }
      }
    ],
    "templating": {
      "list": []
    },
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {}
  }
}
