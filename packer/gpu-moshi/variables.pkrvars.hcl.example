# =============================================================================
# GPU Moshi Demo - Packer Variables
# =============================================================================
# Example variables file - copy to variables.pkrvars.hcl and customize
# =============================================================================

# Required: Your Scaleway project ID
project_id = "your-project-id-here"

# Optional: Scaleway zone (default: fr-par-2)
zone = "fr-par-2"

# Optional: Scaleway region (default: fr-par)
region = "fr-par"

# Optional: Name for the built image
image_name = "gpu-moshi-demo-ubuntu-22.04"

# Optional: Scaleway instance type (L4-24GB GPU)
instance_type = "H100-1-80G"

# Optional: SSH username for provisioning
ssh_username = "root"

# Optional: Disk size in GB
disk_size = 80

# Optional: GPU mode: mig, timeslicing, or both
gpu_mode = "both"
