# Example terraform.tfvars for pre-prod environment
# Copy this file to terraform.tfvars and fill in your values

# Scaleway Configuration
project_id    = "<your-scaleway-project-id>"
region        = "fr-par"
zone          = "fr-par-1"

# Instance Configuration
instance_type = "GPU-3070-S"
instance_name = "gpu-mig-preprod"
tags          = ["pre-prod", "gpu", "testing"]

# K3s Configuration
k3s_version = "v1.28.5+k3s1"

# ArgoCD Configuration
git_repo_url = "https://github.com/jeremie-lesage/gentle-circuit.git"

# Storage Configuration
root_volume_size = 50
image_id         = "ubuntu_jammy"
