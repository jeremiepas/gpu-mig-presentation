# Local GPU Environment Variables
# Generated by Terraform

export GPU_HOST="${gpu_host}"
export GPU_USER="${gpu_user}"
export SSH_KEY_PATH="${ssh_key_path}"

# Service URLs
export K3S_API_URL="${k3s_api_url}"
export GRAFANA_URL="${grafana_url}"
export PROMETHEUS_URL="${prometheus_url}"

# Helper functions
alias ssh-gpu="ssh -i \$SSH_KEY_PATH \$GPU_USER@\$GPU_HOST"
alias kubectl-gpu="ssh -i \$SSH_KEY_PATH \$GPU_USER@\$GPU_HOST 'sudo k3s kubectl'"