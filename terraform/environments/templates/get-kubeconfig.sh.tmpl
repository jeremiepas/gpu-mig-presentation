#!/bin/bash

# Script to retrieve kubeconfig from local GPU machine
# Generated by Terraform

GPU_HOST="${gpu_host}"
GPU_USER="${gpu_user}"
SSH_KEY_PATH="${ssh_key_path}"

echo "Retrieving kubeconfig from GPU machine at $GPU_HOST..."

# Create directory if it doesn't exist
mkdir -p ~/.kube

# Retrieve kubeconfig via SSH
if ssh -i "$SSH_KEY_PATH" -o StrictHostKeyChecking=no "$GPU_USER@$GPU_HOST" "sudo cat /etc/rancher/k3s/k3s.yaml" > ~/.kube/config-gpu-local; then
    # Replace localhost with actual IP
    sed -i "s|127.0.0.1|$GPU_HOST|g" ~/.kube/config-gpu-local
    chmod 600 ~/.kube/config-gpu-local
    
    echo "✅ Successfully retrieved kubeconfig to ~/.kube/config-gpu-local"
    echo ""
    echo "To use this kubeconfig:"
    echo "  export KUBECONFIG=~/.kube/config-gpu-local"
    echo "  kubectl get nodes"
else
    echo "❌ Failed to retrieve kubeconfig"
    exit 1
fi